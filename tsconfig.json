{
  "compilerOptions": {
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": [
      "DOM",
      "ES2024",
      "ESNext.Disposable",
      "ES2024.Promise"
    ],
    "paths": {
      "@app/*": [
        "./front/*"
      ]
    }
  },
  "include": [
    "./front/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}